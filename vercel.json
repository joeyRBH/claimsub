{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "mkdir -p public && cp index.html public/index.html",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/setup-intent", "destination": "/api/setup-intent" },
    { "source": "/save-payment-method", "destination": "/api/save-payment-method" },
    { "source": "/clients/:id/send-payment-link", "destination": "/api/clients/:id/send-payment-link" },
    { "source": "/subscription/vob/activate", "destination": "/api/vob-activate" },
    { "source": "/card-setup", "destination": "/card-setup.html" }
  ]
}
