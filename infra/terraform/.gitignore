# Terraform working dirs / state — never commit.
.terraform/
*.tfstate
*.tfstate.*
crash.log

# Real variable files — only terraform.tfvars.example is tracked.
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
backend.hcl

# Plans may render secret values from state.
*.tfplan
plan.out
plan.txt

# Lambda build artifact — regenerated by archive_file at plan time.
.build/
